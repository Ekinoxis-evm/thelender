# ─────────────────────────────────────────────────────────────
# Copy to .env.local and fill in. NEVER commit the filled file.
# ─────────────────────────────────────────────────────────────

# ── Privy (auth + embedded wallets) ──
# https://dashboard.privy.io  → App settings
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ── RPC / chain access ──
# Working chain: Ethereum Sepolia (11155111). Recommended: Alchemy — one key, every chain.
# Get it at https://dashboard.alchemy.com · URL pattern: https://<chain>.g.alchemy.com/v2/<KEY>
#   eth-sepolia · eth-mainnet · base-sepolia · opt-mainnet · arb-mainnet ...
# In the SE-2 app set NEXT_PUBLIC_ALCHEMY_API_KEY (packages/nextjs/.env.local).
ALCHEMY_API_KEY=
# The SE-2 app reads this one (client-side); set it in packages/nextjs/.env.local:
NEXT_PUBLIC_ALCHEMY_API_KEY=
NEXT_PUBLIC_RPC_URL_SEPOLIA=
NEXT_PUBLIC_RPC_URL_MAINNET=
NEXT_PUBLIC_DEFAULT_CHAIN_ID=11155111

# ── ENS ── (resolution always reads from Ethereum Mainnet — use the mainnet RPC)
NEXT_PUBLIC_ENS_RPC_URL=

# ── KreditoOne (ENSv2 credit identity on Sepolia) ──
# KreditoController address, printed by `yarn deploy --file SetupKreditoEns.s.sol`. Public.
NEXT_PUBLIC_KREDITO_CONTROLLER=
# Backend issuer hot key (holds ISSUER_ROLE) — SERVER ONLY: mints subnames for approved wallets.
# Testnet key only; rotate via the cold DEFAULT_ADMIN if leaked. NEVER prefix NEXT_PUBLIC.
ISSUER_PRIVATE_KEY=

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# For the Supabase MCP server (.mcp.json):
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# ── Chainlink ── (no key needed for on-chain feeds; Functions/Data Streams differ)
# Subscription IDs etc. get filled per-feature.

# ── Railway MCP ──
RAILWAY_API_TOKEN=

# ── Context7 MCP (optional, raises rate limits) ──
CONTEXT7_API_KEY=

# ── GitHub MCP (optional) ──
# The official GitHub MCP (https://api.githubcopilot.com/mcp/) uses OAuth — just
# run /mcp to authorize, no token needed. Only set this if you prefer PAT auth
# (then add an Authorization: Bearer header to the github server in .mcp.json).
GITHUB_PERSONAL_ACCESS_TOKEN=

# ── Vercel MCP ──
# OAuth only — authorize via /mcp. No token here.

# ── Contract deployment + verification (Foundry) — keep OUT of frontend env ──
# Prefer a hardware wallet or `cast wallet`. Only use a raw key on testnet.
DEPLOYER_PRIVATE_KEY=
# Etherscan V2: ONE key verifies across 60+ chains (Mainnet, Base, OP, Arbitrum…).
# Get it at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# ── Blockscout MCP ── (PRO key, prefixed proapi_) https://dev.blockscout.com
BLOCKSCOUT_PRO_API_KEY=

# ── The Graph MCPs ──
# Subgraph MCP — Gateway API key from Subgraph Studio: https://thegraph.com/studio
GRAPH_GATEWAY_API_KEY=
# Token API MCP — JWT access token from The Graph Market: https://thegraph.market
GRAPH_TOKEN_API_JWT=
