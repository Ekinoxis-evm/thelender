# ═══════════════════════════════════════════════════════════════════
# MASTER ENV REFERENCE — documents every key across the monorepo.
# This file is committed and holds NO real values. Nothing reads it at runtime.
#
# There is no single ".env" — env is per-package. Copy values FROM here INTO:
#   • packages/nextjs/.env.local   → the app (frontend + API routes) + Vercel
#   • packages/foundry/.env        → contract deploy + verify ONLY
#   • root .env (this dir)         → MCP servers / tooling used by Claude Code
# NEVER commit a filled file. Each target's own .env.example has the canonical,
# trimmed copy — this is just the bird's-eye map.
# ═══════════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────────
# A) APP  →  packages/nextjs/.env.local   (also mirror into Vercel)
# ───────────────────────────────────────────────────────────────────
# Privy — auth + embedded + sponsored smart wallets (REQUIRED for login)
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=                  # server-only; only if you add server-side Privy

# RPC — Alchemy (one key, every chain). https://dashboard.alchemy.com
NEXT_PUBLIC_ALCHEMY_API_KEY=
NEXT_PUBLIC_ENS_RPC_URL=           # optional; ENS always resolves on Ethereum Mainnet

# Supabase — DB / auth / realtime (REQUIRED)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=         # server-only

# Admin panel (/admin) — a password YOU choose; sent as x-admin-secret. Server-only.
ADMIN_SECRET=

# Kredito vault (ERC-4626 + ERC-7540) — set to the deployed address post-deploy.
NEXT_PUBLIC_KREDITO_VAULT=
# KreditoInsurancePool (COVER reserve) — enables the Liquidity insurance panel.
NEXT_PUBLIC_KREDITO_INSURANCE=

# Issuer signer — server-only. Signs the EIP-712 attestation (/api/lendsignal/attest) AND mints
# ENS identities (/api/identity/mint via KreditoController). MUST equal the Foundry deployer key
# (= vault `issuer` = controller ISSUER_ROLE).
ISSUER_PRIVATE_KEY=

# ENS credit identity — KreditoController + KreditoResolver addresses, printed by SetupKreditoEns.
# Controller is required for the *.kredito.eth mint step; resolver is reserved for profile editing.
NEXT_PUBLIC_KREDITO_CONTROLLER=
NEXT_PUBLIC_KREDITO_RESOLVER=

# Chainlink Confidential AI Attester (LendSignal scoring) — server-only.
# Without a key, /api/lendsignal/score returns a deterministic mock.
CHAINLINK_CONFIDENTIAL_AI_BASE_URL=https://confidential-ai-dev-preview.cldev.cloud
CHAINLINK_CONFIDENTIAL_AI_API_KEY=
CHAINLINK_CONFIDENTIAL_AI_MODEL=gemma4

# Optional SE-2 build flags (next.config.ts)
NEXT_PUBLIC_IGNORE_BUILD_ERROR=
NEXT_PUBLIC_IPFS_BUILD=


# ───────────────────────────────────────────────────────────────────
# B) CONTRACTS  →  packages/foundry/.env   (deploy + verify; keep OUT of frontend)
# ───────────────────────────────────────────────────────────────────
# Deployer = SE-2 keystore account (managed via `yarn generate` / `yarn account:import`),
# NOT a raw key. Its private key MUST match the app's ISSUER_PRIVATE_KEY above.
LOCALHOST_KEYSTORE_ACCOUNT=scaffold-eth-default
# RPC for testnet/mainnet deploys (foundry.toml [rpc_endpoints]).
ALCHEMY_API_KEY=
# Etherscan V2: ONE key verifies across 60+ chains. https://etherscan.io/myapikey
ETHERSCAN_API_KEY=
# Optional: override the vault's underlying asset (verified 6-decimal ERC-20).
KREDITO_ASSET=


# ───────────────────────────────────────────────────────────────────
# C) TOOLING  →  root .env   (MCP servers used by Claude Code — .mcp.json)
# ───────────────────────────────────────────────────────────────────
# Supabase MCP (read-only project access)
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
# Railway MCP
RAILWAY_API_TOKEN=
# Context7 MCP (optional, raises rate limits)
CONTEXT7_API_KEY=
# GitHub MCP — OAuth by default (run /mcp). Only set this if you prefer PAT auth.
GITHUB_PERSONAL_ACCESS_TOKEN=
# Vercel MCP — OAuth only, authorize via /mcp. No token here.
# Blockscout MCP — PRO key, prefixed proapi_. https://dev.blockscout.com
BLOCKSCOUT_PRO_API_KEY=
# The Graph MCPs
GRAPH_GATEWAY_API_KEY=             # Subgraph MCP — Gateway key from https://thegraph.com/studio
GRAPH_TOKEN_API_JWT=               # Token API MCP — JWT from https://thegraph.market
