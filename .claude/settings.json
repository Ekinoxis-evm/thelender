{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git log:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git submodule update:*)",
      "Bash(npx:*)",
      "Bash(yarn install:*)",
      "Bash(yarn compile:*)",
      "Bash(yarn test:*)",
      "Bash(yarn lint:*)",
      "Bash(yarn format:*)",
      "Bash(yarn chain:*)",
      "Bash(yarn start:*)",
      "Bash(yarn foundry:test:*)",
      "Bash(yarn foundry:compile:*)",
      "Bash(yarn foundry:format:*)",
      "Bash(yarn foundry:lint:*)",
      "Bash(yarn foundry:verify:*)",
      "Bash(yarn next:*)",
      "Bash(forge build:*)",
      "Bash(forge test:*)",
      "Bash(forge fmt:*)",
      "Bash(forge install:*)",
      "Bash(forge verify-contract:*)",
      "Bash(anvil:*)",
      "Bash(cast wallet:*)",
      "Bash(cast call:*)",
      "Bash(cast base-fee:*)",
      "Bash(cast code:*)",
      "Bash(cast 4byte:*)",
      "Bash(cast abi-decode:*)",
      "Bash(vercel env pull:*)",
      "Bash(supabase:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)"
    ],
    "ask": [
      "Bash(yarn deploy:*)",
      "Bash(yarn foundry:deploy:*)",
      "Bash(yarn vercel:*)",
      "Bash(forge create:*)",
      "Bash(forge script:*)",
      "Bash(cast send:*)",
      "Bash(vercel deploy:*)",
      "Bash(vercel --prod:*)",
      "Bash(railway up:*)",
      "Bash(git push:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.*.local)",
      "Read(./packages/**/.env)",
      "Read(./packages/**/.env.local)",
      "Read(./**/*.key)",
      "Read(./**/mnemonic.txt)"
    ]
  },
  "env": {
    "NEXT_TELEMETRY_DISABLED": "1"
  }
}
