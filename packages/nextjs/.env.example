# ─────────────────────────────────────────────────────────────
# Next.js app env — packages/nextjs
# Copy to `.env.local` and fill in. NEVER commit the filled file (.env.local is gitignored).
#
# Two kinds of vars live here:
#   • NEXT_PUBLIC_*  → exposed to the BROWSER (client). Safe-to-publish values only.
#   • everything else → SERVER ONLY (API routes / server components). Real secrets.
#
# This is also the set you mirror into Vercel → Project → Settings → Environment Variables.
# (Foundry deploy keys do NOT belong here — they live in packages/foundry/.env.)
# Access in code with: process.env.VARIABLE_NAME
# ─────────────────────────────────────────────────────────────


# ── Privy — auth + embedded + sponsored smart wallets (REQUIRED for login) ──
# App ID from https://dashboard.privy.io. Gas sponsorship is configured in the
# Privy Dashboard (no code toggle) — see docs/privy.md.
NEXT_PUBLIC_PRIVY_APP_ID=
# Server-only. Only needed if you add server-side Privy verification. Never prefix NEXT_PUBLIC.
PRIVY_APP_SECRET=

# ── RPC — Alchemy, one key for every chain (recommended; falls back to SE-2 default) ──
# Get it at https://dashboard.alchemy.com
NEXT_PUBLIC_ALCHEMY_API_KEY=
# Optional: dedicated mainnet RPC for ENS (ENS always resolves on Ethereum Mainnet).
NEXT_PUBLIC_ENS_RPC_URL=

# ── Supabase — DB / auth / realtime (REQUIRED: credit checks + persistence) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — used by API routes for privileged writes (services/supabase/admin.ts). Never NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin panel (/admin) ──
# A password YOU choose. Gates the status dashboard + AI model/prompt management.
# Sent by the browser as the x-admin-secret header and compared server-side
# (app/api/admin/route.ts). SERVER ONLY. If empty, /admin returns 401 for everyone.
ADMIN_SECRET=

# ── Kredito vault (ERC-4626 + ERC-7540) ──
# Set to the deployed KreditoVault address after `yarn deploy --file DeployKreditoVaultV2.s.sol`.
# Required for onchain borrow / liquidity. Public (an address), so NEXT_PUBLIC is fine.
NEXT_PUBLIC_KREDITO_VAULT=
# KreditoInsurancePool address (COVER reserve). Enables the Liquidity "back the pool" + reserve panel.
NEXT_PUBLIC_KREDITO_INSURANCE=

# ── Issuer-signed credit attestation (EIP-712) ──
# Server-only signing key. Used for BOTH: (1) /api/lendsignal/attest (signs the EIP-712
# CreditAttestation the vault verifies) and (2) /api/identity/mint (the backend issuer that
# calls KreditoController.mint). MUST equal the vault's `issuer` AND hold the controller's
# ISSUER_ROLE — i.e. the same key as the Foundry deployer (see packages/foundry/.env). Never NEXT_PUBLIC.
ISSUER_PRIVATE_KEY=

# ── ENS credit identity (ENSv2 *.kredito.eth subnames) ──
# Address of the deployed KreditoController, printed by `yarn deploy --file SetupKreditoEns.s.sol`.
# /api/identity/mint mints `<label>.kredito.eth` through it. Required for the mint step.
NEXT_PUBLIC_KREDITO_CONTROLLER=
# Address of the deployed KreditoResolver (also printed by SetupKreditoEns). Reserved for onchain
# profile editing; not required for minting.
NEXT_PUBLIC_KREDITO_RESOLVER=

# ── Chainlink Confidential AI Attester (LendSignal credit scoring) ──
# SERVER ONLY — consumed by /api/lendsignal/score. Without a key the route returns a mock.
# Key is distributed out of band (Chainlink booth / #partner-chainlink Discord).
CHAINLINK_CONFIDENTIAL_AI_BASE_URL=https://confidential-ai-dev-preview.cldev.cloud
CHAINLINK_CONFIDENTIAL_AI_API_KEY=
CHAINLINK_CONFIDENTIAL_AI_MODEL=gemma4

# ── Optional SE-2 build flags (next.config.ts) ──
# Ignore type/lint errors on build; IPFS build mode. Leave blank for normal dev.
NEXT_PUBLIC_IGNORE_BUILD_ERROR=
NEXT_PUBLIC_IPFS_BUILD=
