# ─────────────────────────────────────────────────────────────
# Foundry env — packages/foundry  (contracts: deploy + verify ONLY)
# Copy to `.env` and fill in. NEVER commit the filled file (.env is gitignored).
#
# This package never touches frontend/app secrets — those live in
# packages/nextjs/.env.local. Keep deploy keys OUT of the frontend env.
# ─────────────────────────────────────────────────────────────


# ── Deployer account (SE-2 keystore pattern — NOT a raw key in env) ──
# The deployer is auto-resolved from a forge keystore account, not from a
# DEPLOYER_PRIVATE_KEY var. Manage it with the yarn scripts:
#   yarn generate         → create a new keystore account
#   yarn account:import   → import an existing private key
#   yarn account          → show the current account + balance
# For local anvil, the default keystore account below uses a prefunded dev key.
# For live deploys, pass --account <name> (or set this to your imported account).
# NOTE: the deployer is also the vault `issuer`; its private key MUST match
# packages/nextjs/.env.local → ISSUER_PRIVATE_KEY (server-side EIP-712 signer).
LOCALHOST_KEYSTORE_ACCOUNT=scaffold-eth-default

# ── RPC — Alchemy, one key for every chain ──
# Used to build the testnet/mainnet RPC URLs in foundry.toml ([rpc_endpoints]).
# Pattern: https://<chain>.g.alchemy.com/v2/${ALCHEMY_API_KEY}
ALCHEMY_API_KEY=

# ── Contract verification — Etherscan V2 ──
# ONE key verifies across 60+ chains (Mainnet, Base, OP, Arbitrum, Polygon…).
# Foundry routes to https://api.etherscan.io/v2/api?chainid=<id> automatically.
# Get it at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# ── Kredito vault asset override (optional) ──
# DeployKreditoVaultV2 resolves USDC per-chain by default
# (anvil = fresh mintable mock; sepolia/mainnet = verified Circle USDC).
# Set this to a verified 6-decimal ERC-20 to override on any chain.
# The deploy reverts if the address has no code or its decimals != 6.
KREDITO_ASSET=

# ── ENS subname issuer (optional) ──
# SetupKreditoEns.s.sol grants the controller's ISSUER_ROLE to this address. Defaults to the
# deployer (correct for the demo, where issuer == deployer == the app's ISSUER_PRIVATE_KEY).
# Set only if a separate backend hot key should mint identities.
KREDITO_ISSUER=0x4B24116Df4C31c40aB5B3cb3bA3Ffe743A346978
